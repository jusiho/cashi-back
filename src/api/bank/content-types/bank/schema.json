{
  "kind": "collectionType",
  "collectionName": "banks",
  "info": {
    "singularName": "bank",
    "pluralName": "banks",
    "displayName": "Bank",
    "description": "Financial institutions (banks)"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "minLength": 2,
      "maxLength": 100
    },
    "color": {
      "type": "string",
      "default": "#3B82F6"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "accounts": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::account.account",
      "mappedBy": "bank"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
