{
  "kind": "collectionType",
  "collectionName": "categories",
  "info": {
    "singularName": "category",
    "pluralName": "categories",
    "displayName": "Category",
    "description": "Transaction categories"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "minLength": 2,
      "maxLength": 100
    },
    "icon": {
      "type": "string",
      "default": "tag"
    },
    "color": {
      "type": "string",
      "default": "#6B7280"
    },
    "type": {
      "type": "enumeration",
      "enum": ["income", "expense", "both"],
      "default": "both",
      "required": true
    },
    "isDefault": {
      "type": "boolean",
      "default": false
    },
    "transactions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::transaction.transaction",
      "mappedBy": "category"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
