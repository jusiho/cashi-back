{
  "kind": "collectionType",
  "collectionName": "subscriptions",
  "info": {
    "singularName": "subscription",
    "pluralName": "subscriptions",
    "displayName": "Subscription",
    "description": "User subscription plans and billing info"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "plan": {
      "type": "enumeration",
      "enum": ["free", "pro"],
      "default": "free",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["active", "canceled", "past_due", "trialing"],
      "default": "active",
      "required": true
    },
    "stripeCustomerId": {
      "type": "string",
      "unique": true
    },
    "stripeSubscriptionId": {
      "type": "string",
      "unique": true
    },
    "currentPeriodEnd": {
      "type": "datetime"
    },
    "paymentProvider": {
      "type": "enumeration",
      "enum": ["stripe", "izipay"],
      "default": "stripe"
    },
    "providerToken": {
      "type": "string"
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
