# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=cashi
POSTGRES_USER=cashi
POSTGRES_PASSWORD=supersecretpassword

# ── Strapi secrets ─────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_KEYS=key1base64,key2base64,key3base64,key4base64
API_TOKEN_SALT=randombase64string
ADMIN_JWT_SECRET=randombase64string
JWT_SECRET=randombase64string
TRANSFER_TOKEN_SALT=randombase64string

# ── WhatsApp Cloud API ─────────────────────────────────────────
WHATSAPP_TOKEN=EAAxxxxx...
WHATSAPP_PHONE_NUMBER_ID=123456789
WHATSAPP_API_VERSION=v22.0
WHATSAPP_VERIFY_TOKEN=mi_token_secreto

# ── OpenAI ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Stripe ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ────────────────────────────────────────────────────────
APP_URL=https://tudominio.com
STRAPI_PORT=1337

# ── Next.js ────────────────────────────────────────────────────
NEXT_PUBLIC_STRAPI_URL=https://api.tudominio.com
NEXTAUTH_URL=https://tudominio.com
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=randombase64string
NEXTJS_PORT=3000
